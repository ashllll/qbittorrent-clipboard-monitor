# qBittorrent剪贴板监控工具 - 环境变量配置模板
# 
# 使用方法：
# 1. 复制此文件为 .env
# 2. 填写所有必需的环境变量
# 3. 确保 .env 文件已添加到 .gitignore

# ============================================================================
# qBittorrent 配置（必需）
# ============================================================================

# qBittorrent 服务器地址
QBIT_HOST=localhost

# qBittorrent 服务器端口
QBIT_PORT=8080

# qBittorrent 用户名
QBIT_USERNAME=admin

# qBittorrent 密码（必需，必须设置）
QBIT_PASSWORD=

# 是否使用 HTTPS（生产环境建议设置为 true）
QBIT_USE_HTTPS=false

# ============================================================================
# AI 配置（可选）
# ============================================================================

# AI 分类功能开关
AI_ENABLED=false

# DeepSeek/OpenAI API 密钥
AI_API_KEY=

# AI 模型名称
AI_MODEL=deepseek-chat

# API 基础 URL（用于兼容其他 OpenAI 格式 API）
AI_BASE_URL=https://api.deepseek.com/v1

# ============================================================================
# 应用配置（可选）
# ============================================================================

# 剪贴板检查间隔（秒）
CHECK_INTERVAL=1.0

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
