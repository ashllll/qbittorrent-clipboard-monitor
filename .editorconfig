# EditorConfig is awesome: https://EditorConfig.org
# 统一编辑器配置，确保跨编辑器一致性

# 根配置文件
root = true

# ========== 全局设置 ==========
[*]
# 使用 UTF-8 编码
charset = utf-8

# 使用 Unix 风格的换行符
end_of_line = lf

# 文件末尾插入空行
insert_final_newline = true

# 删除行尾空白字符
trim_trailing_whitespace = true

# 缩进使用空格
indent_style = space

# 默认缩进宽度
indent_size = 4

# 最大行长度 (与 black/flake8 一致)
max_line_length = 100

# ========== Python 文件 ==========
[*.py]
indent_size = 4
max_line_length = 100

# ========== YAML 文件 ==========
[*.{yaml,yml}]
indent_size = 2
max_line_length = 100

# ========== JSON 文件 ==========
[*.json]
indent_size = 2
insert_final_newline = false
max_line_length = 100

# ========== Markdown 文件 ==========
[*.md]
indent_size = 2
trim_trailing_whitespace = false
max_line_length = 100

# ========== TOML 文件 ==========
[*.toml]
indent_size = 2
max_line_length = 100

# ========== INI/CFG 文件 ==========
[*.{ini,cfg}]
indent_size = 4
max_line_length = 100

# ========== Shell 脚本 ==========
[*.sh]
indent_size = 2
max_line_length = 100

# ========== Dockerfile ==========
[Dockerfile]
indent_size = 4
max_line_length = 100

# ========== Docker Compose ==========
[{docker-compose.yml,docker-compose.yaml,Dockerfile*}]
indent_size = 2
max_line_length = 100

# ========== Makefile ==========
[{Makefile,makefile,*.mk}]
indent_style = tab
indent_size = 4

# ========== Web 文件 ==========
[*.{html,css,js,ts,jsx,tsx}]
indent_size = 2
max_line_length = 100

# ========== XML 文件 ==========
[*.xml]
indent_size = 2
max_line_length = 100

# ========== Requirements 文件 ==========
[{requirements*.txt,Pipfile}]
indent_size = 4
max_line_length = 100
